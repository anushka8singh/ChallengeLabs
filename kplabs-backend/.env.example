# ===========================================
# KPLabs Backend - Environment Configuration
# Phase 1 Foundation
# ===========================================

# Application
NODE_ENV=development
PORT=4000
APP_NAME=KPLabs Linux Lab API

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://kplabs:kplabs_dev_password@localhost:5432/kplabs?schema=public"

# ===========================================
# Redis
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# JWT (Prepared for Phase 2)
# ===========================================
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=7d

# ===========================================
# Docker (Prepared for Phase 3)
# ===========================================
# DOCKER_HOST=unix:///var/run/docker.sock
# CONTAINER_IMAGE_PREFIX=kplabs/

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
